strategy(
    "VIX Crossing",
    overlay=true,
    commission_type = strategy.commission.cash_per_contract,
    commission_value = 3,
    initial_capital = 50000
)

vixSmaLength = input.int(5, 'VIX SMA Length')
ndxEmaLength = input.int(21, 'NDX EMA Length')
forceCloseAfterBars = input.int(10, 'Force close after X bars from entry')
tpAmountPerContract = input.float(
    3000, 'TP Amount per contract', minval = 0,
    tooltip = 'If the profit per contract is greater than this amount, close the position'
)
slAmountPerContract = input.float(
    1500, 'TP Amount per contract', minval = 0,
    tooltip = 'If the loss per contract is greater than this amount, close the position'
)

[vixClose, vixSma] = request.security('VIX', '', [close, ta.sma(close, vixSmaLength)])
[ndxClose, ndxEma] = request.security('NDX', '', [close, ta.sma(close, ndxEmaLength)])

var int barsSinceEntry = 0

if ta.crossunder(vixClose, vixSma) and ndxClose > ndxEma
    strategy.entry('long', strategy.long)

closeCondition1 = ta.crossover(vixClose, vixSma)
closeCondition2 = barsSinceEntry > forceCloseAfterBars
closeCondition3 = strategy.openprofit > tpAmountPerContract * strategy.position_size
closeCondition4 = strategy.openprofit < -slAmountPerContract * strategy.position_size

if strategy.position_size != 0
    barsSinceEntry += 1

    if closeCondition1
        strategy.close_all(str.format('VIX > {0} SMA', vixSmaLength))
        barsSinceEntry := 0
    if closeCondition2
        strategy.close_all(str.format('{0} bars force close', forceCloseAfterBars))
        barsSinceEntry := 0
    if closeCondition3
        strategy.close_all(str.format('TP ${0}', tpAmountPerContract))
        barsSinceEntry := 0
    if closeCondition4
        strategy.close_all(str.format('SL -${0}', slAmountPerContract))
        barsSinceEntry := 0
