//@version=6
indicator('Volume Cluster Zones + TP/SL', overlay=true, max_boxes_count=500, max_bars_back=5000, max_lines_count=500, max_labels_count=500)

// High Volume Detection
short_length   = input.int(5,   'Short Period',  minval = 1, group = 'High Volume Detection')
long_length    = input.int(50,  'Long Period',   minval = 1, group = 'High Volume Detection')
high_mult      = input.float(1.7, 'High Volume Multiplier', step = 0.1, group = 'High Volume Detection')

// Box Style
bullZoneColor     = input.color(#26a69a,  title = 'Bull Zone Color',     group = 'Box Style')
bearZoneColor     = input.color(#ef5350, title = 'Bear Zone Color',     group = 'Box Style')
zoneTransparency  = input.int(70, 'Zone Transparency', minval = 0, maxval = 100, group = 'Box Style')
midLineTranspPct  = input.int(70, 'Midline Transparency', minval = 0, maxval = 100, group = 'Box Style')

showZoneWeightedPrice = input.bool(true,  'Show Zone Weighted Price Line', group = 'Box Style')
zoneWeightedPriceColor = input.color(color.rgb(131, 131, 131), 'Zone Weighted Price Line Color', group = 'Box Style')
zoneWeightedPriceWidth = input.int(2, 'Zone Weighted Price Line Width', minval = 1, maxval = 5, group = 'Box Style')

zoneBorderWidth   = input.int(1, title = 'Border Width', minval = 1, maxval = 5, group = 'Box Style')
showProportions   = input.bool(true, 'Show Bull/Bear Volume Proportions (left = bull, right = bear)', group = 'Box Style')

// Signal Style
breakUpSignalColor  = input.color(#26a69a, title = 'Break Up Signal Color',  group = 'Signal Style')
breakDownSignalColor= input.color(#ef5350, title = 'Break Down Signal Color',group = 'Signal Style')
exitUpSignalColor   = input.color(#26a69a, title = 'Exit Up Signal Color',   group = 'Signal Style')
exitDownSignalColor = input.color(#ef5350, title = 'Exit Down Signal Color', group = 'Signal Style')

signalType = input.string('Break', title = 'Signal Type', options = ['Break', 'Exit', 'Both'], group = 'Signal Style')
showBreakSignals = signalType == 'Break' or signalType == 'Both'
showExitSignals  = signalType == 'Exit'  or signalType == 'Both'

signalSize = input.string("small", title = 'Signal Size', options = ["tiny","small","normal"], group = 'Signal Style')

// TP/SL Settings
show_targets   = input.bool(true,  "Show TP/SL Targets", group = "TP/SL Settings")

tp_sl_on_break_up   = input.bool(true,  "Generate TP/SL on Break Up",   group = "TP/SL Settings")
tp_sl_on_break_down = input.bool(true,  "Generate TP/SL on Break Down", group = "TP/SL Settings")
tp_sl_on_exit_up    = input.bool(false, "Generate TP/SL on Exit Up",    group = "TP/SL Settings")
tp_sl_on_exit_down  = input.bool(false, "Generate TP/SL on Exit Down",  group = "TP/SL Settings")

use_atr_sl     = input.bool(true,  "Use ATR × for SL instead of %", group = "TP/SL Settings")
atr_period     = input.int(14,     "ATR Period", minval=1, group = "TP/SL Settings")
sl_atr_mult    = input.float(1.5,  "SL ATR Multiplier", step=0.1, group = "TP/SL Settings")
sl_percent     = input.float(1.0,  "SL % from Entry", step=0.1, group = "TP/SL Settings")

rr_tp1         = input.float(1.0,  "TP1 Risk-Reward Ratio", step=0.1, group = "TP/SL Settings")
rr_tp2         = input.float(2.0,  "TP2 Risk-Reward Ratio", step=0.1, group = "TP/SL Settings")
rr_tp3         = input.float(3.0,  "TP3 Risk-Reward Ratio", step=0.1, group = "TP/SL Settings")

show_sl_level  = input.bool(true,  "Show SL Level",  group = "TP/SL Settings")
show_tp1_level = input.bool(true,  "Show TP1 Level", group = "TP/SL Settings")
show_tp2_level = input.bool(true,  "Show TP2 Level", group = "TP/SL Settings")
show_tp3_level = input.bool(true,  "Show TP3 Level", group = "TP/SL Settings")

// Colors for TP/SL levels
longColor      = breakUpSignalColor   
shortColor     = breakDownSignalColor 

// Constants
BULL_BORDER_STYLE = line.style_solid
BEAR_BORDER_STYLE = line.style_solid

// Volume Formatting
format_volume(float v) =>
    if v >= 1000000
        str.tostring(v / 1000000, "#.##") + "M"
    else if v >= 1000
        str.tostring(v / 1000, "#.##") + "K"
    else
        str.tostring(math.round(v))

// Calculations
vol_short  = ta.sma(volume, short_length)
vol_long   = ta.sma(volume, long_length)
vol_regime = vol_short / math.max(vol_long, 0.000001)

isHighVolume = vol_regime >= high_mult
atr_val = ta.atr(atr_period)

// Arrays
var array<float> zoneTop        = array.new_float(0)
var array<float> zoneBot        = array.new_float(0)
var array<int>   zoneBarIndices = array.new_int(0)
var array<bool>  isBull         = array.new_bool(0)
var array<bool>  activeZones    = array.new_bool(0)
var array<box>   boxes          = array.new_box(0)
var array<bool>  insideZone     = array.new_bool(0)
var array<line>  midLines       = array.new_line(0)

var array<float> bullVolumes    = array.new_float(0)
var array<float> bearVolumes    = array.new_float(0)
var array<box>   bullSubBoxes   = array.new_box(0)
var array<box>   bearSubBoxes   = array.new_box(0)
var array<label> volumeLabels   = array.new_label(0)

// Zone Weighted Average Price
var array<float> zoneSumPriceVol      = array.new_float(0)
var array<float> zoneTotalVol         = array.new_float(0)
var array<float> zoneWeightedPrice    = array.new_float(0)
var array<line>  zoneWeightedPriceLines = array.new_line(0)

// TP/SL Management
var int   trade_dir       = 0
var float sl_level        = na
var float extreme_level   = na
var line  entry_line      = na
var label entry_label     = na
var line  sl_line         = na
var label sl_label        = na
var line  tp1_line        = na
var label tp1_label       = na
var line  tp2_line        = na
var label tp2_label       = na
var line  tp3_line        = na
var label tp3_label       = na
var line  extreme_line    = na
var linefill risk_fill    = na
var linefill reward_fill  = na
var int   entry_bar       = na

// Cleanup Inactive Zones
if array.size(zoneTop) > 0
    int size = array.size(zoneTop)
    for i = 0 to size - 1
        int idx = size - 1 - i
        if not array.get(activeZones, idx) or bar_index - array.get(zoneBarIndices, idx) > 500
            box.delete(array.get(boxes, idx))
            line.delete(array.get(midLines, idx))
            line.delete(array.get(zoneWeightedPriceLines, idx))
            box.delete(array.get(bullSubBoxes, idx))
            box.delete(array.get(bearSubBoxes, idx))
            label.delete(array.get(volumeLabels, idx))

            array.remove(zoneTop, idx)
            array.remove(zoneBot, idx)
            array.remove(zoneBarIndices, idx)
            array.remove(isBull, idx)
            array.remove(activeZones, idx)
            array.remove(boxes, idx)
            array.remove(insideZone, idx)
            array.remove(midLines, idx)
            array.remove(bullVolumes, idx)
            array.remove(bearVolumes, idx)
            array.remove(bullSubBoxes, idx)
            array.remove(bearSubBoxes, idx)
            array.remove(volumeLabels, idx)
            array.remove(zoneSumPriceVol, idx)
            array.remove(zoneTotalVol, idx)
            array.remove(zoneWeightedPrice, idx)
            array.remove(zoneWeightedPriceLines, idx)

// High Volume Cluster Detection
bool startNewCluster = isHighVolume and (
    array.size(zoneTop) == 0 or 
    not array.get(activeZones, array.size(zoneTop) - 1) or 
    not isHighVolume[1]
)

if startNewCluster
    array.push(zoneTop, high)
    array.push(zoneBot, low)
    array.push(zoneBarIndices, bar_index)
    array.push(isBull, close > open)
    array.push(activeZones, true)
    array.push(boxes, na)
    array.push(insideZone, false)
    array.push(midLines, na)
    array.push(bullVolumes, 0.0)
    array.push(bearVolumes, 0.0)
    array.push(bullSubBoxes, na)
    array.push(bearSubBoxes, na)
    array.push(volumeLabels, na)
    array.push(zoneSumPriceVol, 0.0)
    array.push(zoneTotalVol, 0.0)
    array.push(zoneWeightedPrice, close)
    array.push(zoneWeightedPriceLines, na)

else if isHighVolume and array.size(zoneTop) > 0
    int lastIdx = array.size(zoneTop) - 1
    if array.get(activeZones, lastIdx)
        float newTop = math.max(array.get(zoneTop, lastIdx), high)
        float newBot = math.min(array.get(zoneBot, lastIdx), low)
        array.set(zoneTop, lastIdx, newTop)
        array.set(zoneBot, lastIdx, newBot)

// Update Zones, Volume & Weighted Price
if array.size(zoneTop) > 0
    for i = 0 to array.size(zoneTop) - 1
        if array.get(activeZones, i) and bar_index - array.get(zoneBarIndices, i) <= 500

            float candle_high = high
            float candle_low  = low
            float candle_close = close
            float candle_vol  = volume
            float zone_top    = array.get(zoneTop, i)
            float zone_bot    = array.get(zoneBot, i)

            if candle_high > zone_bot and candle_low < zone_top
                float overlap_high = math.min(candle_high, zone_top)
                float overlap_low  = math.max(candle_low, zone_bot)
                float overlap_range = overlap_high - overlap_low
                float candle_range  = math.max(candle_high - candle_low, syminfo.mintick)
                float overlap_fraction = overlap_range / candle_range

                float added_vol = candle_vol * overlap_fraction
                float overlap_mid = (overlap_high + overlap_low) / 2

                float bullPart = (candle_close - candle_low) / candle_range
                float bearPart = (candle_high - candle_close) / candle_range
                float add_bull = added_vol * bullPart
                float add_bear = added_vol * bearPart

                array.set(bullVolumes, i, array.get(bullVolumes, i) + add_bull)
                array.set(bearVolumes, i, array.get(bearVolumes, i) + add_bear)

                array.set(zoneSumPriceVol, i, array.get(zoneSumPriceVol, i) + added_vol * overlap_mid)
                array.set(zoneTotalVol, i, array.get(zoneTotalVol, i) + added_vol)

                float weightedPriceLevel = array.get(zoneTotalVol, i) > 0 
                     ? array.get(zoneSumPriceVol, i) / array.get(zoneTotalVol, i) 
                     : overlap_mid
                array.set(zoneWeightedPrice, i, weightedPriceLevel)

            // Draw main zone box
            box.delete(array.get(boxes, i))

            bool zoneIsBull  = array.get(isBull, i)
            color borderColor = zoneIsBull ? bullZoneColor : bearZoneColor

            color mainBgColor = showProportions 
                 ? color.new(color.white, 100) 
                 : color.new(zoneIsBull ? bullZoneColor : bearZoneColor, zoneTransparency)

            float topPrice = array.get(zoneTop, i)
            float botPrice = array.get(zoneBot, i)
            int leftBar    = array.get(zoneBarIndices, i)
            int rightBar   = math.min(bar_index, leftBar + 500)

            box b = box.new(left = leftBar, top = topPrice, right = rightBar, bottom = botPrice,
                            border_color = borderColor, border_width = zoneBorderWidth, 
                            border_style = zoneIsBull ? BULL_BORDER_STYLE : BEAR_BORDER_STYLE,
                            bgcolor = mainBgColor, xloc = xloc.bar_index, extend = extend.none)
            array.set(boxes, i, b)

            // Midline
            float midPrice = (topPrice + botPrice) / 2
            line.delete(array.get(midLines, i))
            line l = line.new(x1 = leftBar, y1 = midPrice, x2 = rightBar, y2 = midPrice,
                              xloc = xloc.bar_index, color = color.new(borderColor, midLineTranspPct), style = line.style_dashed)
            array.set(midLines, i, l)

            // Weighted Price Line
            line.delete(array.get(zoneWeightedPriceLines, i))
            if showZoneWeightedPrice
                float priceLevel = array.get(zoneWeightedPrice, i)
                if not na(priceLevel) and priceLevel >= botPrice and priceLevel <= topPrice
                    line v = line.new(leftBar, priceLevel, rightBar, priceLevel,
                        xloc = xloc.bar_index,
                        color = zoneWeightedPriceColor,
                        width = zoneWeightedPriceWidth,
                        style = line.style_solid)
                    array.set(zoneWeightedPriceLines, i, v)

            // Volume Label
            label.delete(array.get(volumeLabels, i))

            float totalVol = array.get(bullVolumes, i) + array.get(bearVolumes, i)
            float deltaVol = array.get(bullVolumes, i) - array.get(bearVolumes, i)
            float deltaPct = totalVol > 0 ? (deltaVol / totalVol) * 100 : 0

            string labelText = "Vol: " + format_volume(totalVol) + 
                               " | Δ: " + (deltaVol >= 0 ? "+" : "") + format_volume(deltaVol) +
                               " (" + (deltaPct >= 0 ? "+" : "") + str.tostring(deltaPct, "#.#") + "%)"

            label volLabel = label.new(
                 x = rightBar + 2,
                 y = midPrice,
                 text = labelText,
                 xloc = xloc.bar_index,
                 yloc = yloc.price,
                 style = label.style_label_left,
                 color = color.new(color.white, 100),
                 textcolor = borderColor,
                 size = size.normal,
                 textalign = text.align_left
            )
            array.set(volumeLabels, i, volLabel)

            // Proportions
            if showProportions
                float bv  = array.get(bullVolumes, i)
                float brv = array.get(bearVolumes, i)
                float total = bv + brv
                float bullPct = total > 0 ? bv / total : 0.5

                int bullRight = leftBar + math.round((rightBar - leftBar) * bullPct)

                color bullBg = color.new(bullZoneColor, zoneTransparency)
                color bearBg = color.new(bearZoneColor, zoneTransparency)

                box bullSub = array.get(bullSubBoxes, i)
                box bearSub = array.get(bearSubBoxes, i)

                if na(bullSub) or na(bearSub)
                    bullSub := box.new(leftBar, topPrice, bullRight, botPrice, border_color=na, bgcolor=bullBg, xloc=xloc.bar_index)
                    bearSub := box.new(bullRight, topPrice, rightBar, botPrice, border_color=na, bgcolor=bearBg, xloc=xloc.bar_index)
                    array.set(bullSubBoxes, i, bullSub)
                    array.set(bearSubBoxes, i, bearSub)
                else
                    box.set_left(bullSub, leftBar)
                    box.set_right(bullSub, bullRight)
                    box.set_top(bullSub, topPrice)
                    box.set_bottom(bullSub, botPrice)
                    box.set_bgcolor(bullSub, bullBg)

                    box.set_left(bearSub, bullRight)
                    box.set_right(bearSub, rightBar)
                    box.set_top(bearSub, topPrice)
                    box.set_bottom(bearSub, botPrice)
                    box.set_bgcolor(bearSub, bearBg)

// Signals Logic
var bool buySignal = false
var bool sellSignal = false
var bool exitBuySignal = false
var bool exitSellSignal = false
buySignal := false
sellSignal := false
exitBuySignal := false
exitSellSignal := false

if array.size(zoneTop) > 0
    for i = 0 to array.size(zoneTop) - 1
        if array.get(activeZones, i)
            float topPrice = array.get(zoneTop, i)
            float botPrice = array.get(zoneBot, i)
            bool wasInside = array.get(insideZone, i)
            bool isInside = close >= botPrice and close <= topPrice
            array.set(insideZone, i, isInside)

            if array.get(isBull, i) and close < botPrice
                array.set(activeZones, i, false)
                sellSignal := true
            else if not array.get(isBull, i) and close > topPrice
                array.set(activeZones, i, false)
                buySignal := true
            else if wasInside and not isInside
                if array.get(isBull, i) and close > topPrice
                    exitBuySignal := true
                else if not array.get(isBull, i) and close < botPrice
                    exitSellSignal := true

// TP/SL Logic
if show_targets
    // Long signals (Break Up or Exit Up)
    if (tp_sl_on_break_up and buySignal) or (tp_sl_on_exit_up and exitBuySignal)
        line.delete(entry_line)
        label.delete(entry_label)
        line.delete(sl_line)
        label.delete(sl_label)
        line.delete(tp1_line)
        label.delete(tp1_label)
        line.delete(tp2_line)
        label.delete(tp2_label)
        line.delete(tp3_line)
        label.delete(tp3_label)
        line.delete(extreme_line)
        linefill.delete(risk_fill)
        linefill.delete(reward_fill)

        trade_dir := 1
        entry_bar := bar_index
        float entry_price = close
        float risk_dist = use_atr_sl ? atr_val * sl_atr_mult : entry_price * (sl_percent / 100)
        sl_level := entry_price - risk_dist

        float tp1_p = entry_price + risk_dist * rr_tp1
        float tp2_p = entry_price + risk_dist * rr_tp2
        float tp3_p = entry_price + risk_dist * rr_tp3

        float max_tp = na
        if show_tp3_level
            max_tp := tp3_p
        if show_tp2_level
            max_tp := na(max_tp) ? tp2_p : math.max(max_tp, tp2_p)
        if show_tp1_level
            max_tp := na(max_tp) ? tp1_p : math.max(max_tp, tp1_p)
        extreme_level := max_tp

        entry_line := line.new(bar_index, entry_price, bar_index + 1, entry_price, color = longColor, width = 1, extend = extend.right)
        entry_label := label.new(bar_index, entry_price, "LONG " + str.tostring(entry_price, format.mintick), style = label.style_label_left, color = longColor, textcolor = color.white, size = size.small)

        if show_sl_level
            sl_line := line.new(bar_index, sl_level, bar_index + 1, sl_level, color = color.new(shortColor, 40), width = 1, style = line.style_dashed, extend = extend.right)
            sl_label := label.new(bar_index, sl_level, "SL " + str.tostring(sl_level, format.mintick), style = label.style_label_left, color = color.new(shortColor, 40), textcolor = color.white, size = size.small)

        if show_tp1_level
            tp1_line := line.new(bar_index, tp1_p, bar_index + 1, tp1_p, color = color.new(longColor, 40), width = 1, extend = extend.right)
            tp1_label := label.new(bar_index, tp1_p, "TP1 " + str.tostring(tp1_p, format.mintick), style = label.style_label_left, color = color.new(longColor, 40), textcolor = color.white, size = size.small)

        if show_tp2_level
            tp2_line := line.new(bar_index, tp2_p, bar_index + 1, tp2_p, color = color.new(longColor, 40), width = 1, extend = extend.right)
            tp2_label := label.new(bar_index, tp2_p, "TP2 " + str.tostring(tp2_p, format.mintick), style = label.style_label_left, color = color.new(longColor, 40), textcolor = color.white, size = size.small)

        if show_tp3_level
            tp3_line := line.new(bar_index, tp3_p, bar_index + 1, tp3_p, color = color.new(longColor, 40), width = 1, style = line.style_dotted, extend = extend.right)
            tp3_label := label.new(bar_index, tp3_p, "TP3 " + str.tostring(tp3_p, format.mintick), style = label.style_label_left, color = color.new(longColor, 40), textcolor = color.white, size = size.small)

        if show_sl_level
            risk_fill := linefill.new(entry_line, sl_line, color.new(shortColor, 70))

        float max_tp_for_fill = entry_price
        if show_tp1_level
            max_tp_for_fill := math.max(max_tp_for_fill, tp1_p)
        if show_tp2_level
            max_tp_for_fill := math.max(max_tp_for_fill, tp2_p)
        if show_tp3_level
            max_tp_for_fill := math.max(max_tp_for_fill, tp3_p)

        if max_tp_for_fill > entry_price
            extreme_line := line.new(bar_index, max_tp_for_fill, bar_index + 1, max_tp_for_fill, color = na, extend = extend.right)
            reward_fill := linefill.new(entry_line, extreme_line, color.new(longColor, 70))

    // Short signals (Break Down or Exit Down)
    if (tp_sl_on_break_down and sellSignal) or (tp_sl_on_exit_down and exitSellSignal)
        line.delete(entry_line)
        label.delete(entry_label)
        line.delete(sl_line)
        label.delete(sl_label)
        line.delete(tp1_line)
        label.delete(tp1_label)
        line.delete(tp2_line)
        label.delete(tp2_label)
        line.delete(tp3_line)
        label.delete(tp3_label)
        line.delete(extreme_line)
        linefill.delete(risk_fill)
        linefill.delete(reward_fill)

        trade_dir := -1
        entry_bar := bar_index
        float entry_price = close
        float risk_dist = use_atr_sl ? atr_val * sl_atr_mult : entry_price * (sl_percent / 100)
        sl_level := entry_price + risk_dist

        float tp1_p = entry_price - risk_dist * rr_tp1
        float tp2_p = entry_price - risk_dist * rr_tp2
        float tp3_p = entry_price - risk_dist * rr_tp3

        float min_tp = na
        if show_tp3_level
            min_tp := tp3_p
        if show_tp2_level
            min_tp := na(min_tp) ? tp2_p : math.min(min_tp, tp2_p)
        if show_tp1_level
            min_tp := na(min_tp) ? tp1_p : math.min(min_tp, tp1_p)
        extreme_level := min_tp

        entry_line := line.new(bar_index, entry_price, bar_index + 1, entry_price, color = shortColor, width = 1, extend = extend.right)
        entry_label := label.new(bar_index, entry_price, "SHORT " + str.tostring(entry_price, format.mintick), style = label.style_label_left, color = shortColor, textcolor = color.white, size = size.small)

        if show_sl_level
            sl_line := line.new(bar_index, sl_level, bar_index + 1, sl_level, color = color.new(shortColor, 40), width = 1, style = line.style_dashed, extend = extend.right)
            sl_label := label.new(bar_index, sl_level, "SL " + str.tostring(sl_level, format.mintick), style = label.style_label_left, color = color.new(shortColor, 40), textcolor = color.white, size = size.small)

        if show_tp1_level
            tp1_line := line.new(bar_index, tp1_p, bar_index + 1, tp1_p, color = color.new(longColor, 40), width = 1, extend = extend.right)
            tp1_label := label.new(bar_index, tp1_p, "TP1 " + str.tostring(tp1_p, format.mintick), style = label.style_label_left, color = color.new(longColor, 40), textcolor = color.white, size = size.small)

        if show_tp2_level
            tp2_line := line.new(bar_index, tp2_p, bar_index + 1, tp2_p, color = color.new(longColor, 40), width = 1, extend = extend.right)
            tp2_label := label.new(bar_index, tp2_p, "TP2 " + str.tostring(tp2_p, format.mintick), style = label.style_label_left, color = color.new(longColor, 40), textcolor = color.white, size = size.small)

        if show_tp3_level
            tp3_line := line.new(bar_index, tp3_p, bar_index + 1, tp3_p, color = color.new(longColor, 40), width = 1, style = line.style_dotted, extend = extend.right)
            tp3_label := label.new(bar_index, tp3_p, "TP3 " + str.tostring(tp3_p, format.mintick), style = label.style_label_left, color = color.new(longColor, 40), textcolor = color.white, size = size.small)

        if show_sl_level
            risk_fill := linefill.new(entry_line, sl_line, color.new(shortColor, 70))

        float min_tp_for_fill = entry_price
        if show_tp1_level
            min_tp_for_fill := math.min(min_tp_for_fill, tp1_p)
        if show_tp2_level
            min_tp_for_fill := math.min(min_tp_for_fill, tp2_p)
        if show_tp3_level
            min_tp_for_fill := math.min(min_tp_for_fill, tp3_p)

        if min_tp_for_fill < entry_price
            extreme_line := line.new(bar_index, min_tp_for_fill, bar_index + 1, min_tp_for_fill, color = na, extend = extend.right)
            reward_fill := linefill.new(entry_line, extreme_line, color.new(longColor, 70))

// Update TP/SL Labels and Close on Hit
if trade_dir != 0
    label.set_x(entry_label, bar_index)
    if not na(sl_label)
        label.set_x(sl_label, bar_index)
    if not na(tp1_label)
        label.set_x(tp1_label, bar_index)
    if not na(tp2_label)
        label.set_x(tp2_label, bar_index)
    if not na(tp3_label)
        label.set_x(tp3_label, bar_index)

    bool sl_hit = false
    bool tp_hit = false
    if trade_dir == 1
        sl_hit := low <= sl_level
        tp_hit := not na(extreme_level) and high >= extreme_level
    else if trade_dir == -1
        sl_hit := high >= sl_level
        tp_hit := not na(extreme_level) and low <= extreme_level

    if bar_index > entry_bar and (sl_hit or tp_hit)
        line.set_extend(entry_line, extend.none)
        line.set_x2(entry_line, bar_index)
        if not na(sl_line)
            line.set_extend(sl_line, extend.none)
            line.set_x2(sl_line, bar_index)
        if not na(tp1_line)
            line.set_extend(tp1_line, extend.none)
            line.set_x2(tp1_line, bar_index)
        if not na(tp2_line)
            line.set_extend(tp2_line, extend.none)
            line.set_x2(tp2_line, bar_index)
        if not na(tp3_line)
            line.set_extend(tp3_line, extend.none)
            line.set_x2(tp3_line, bar_index)
        if not na(extreme_line)
            line.set_extend(extreme_line, extend.none)
            line.set_x2(extreme_line, bar_index)
        trade_dir := 0

// Plot Signals
plotshape(showBreakSignals and buySignal  and signalSize == "tiny",   title='Break Up Tiny',   location=location.belowbar, style=shape.triangleup,   color=breakUpSignalColor,  size=size.tiny)
plotshape(showBreakSignals and buySignal  and signalSize == "small",  title='Break Up Small',  location=location.belowbar, style=shape.triangleup,   color=breakUpSignalColor,  size=size.small)
plotshape(showBreakSignals and buySignal  and signalSize == "normal", title='Break Up Normal', location=location.belowbar, style=shape.triangleup,   color=breakUpSignalColor,  size=size.normal)

plotshape(showBreakSignals and sellSignal and signalSize == "tiny",   title='Break Down Tiny',   location=location.abovebar, style=shape.triangledown, color=breakDownSignalColor, size=size.tiny)
plotshape(showBreakSignals and sellSignal and signalSize == "small",  title='Break Down Small',  location=location.abovebar, style=shape.triangledown, color=breakDownSignalColor, size=size.small)
plotshape(showBreakSignals and sellSignal and signalSize == "normal", title='Break Down Normal', location=location.abovebar, style=shape.triangledown, color=breakDownSignalColor, size=size.normal)

plotshape(showExitSignals  and exitBuySignal  and signalSize == "tiny",   title='Exit Up Tiny',   location=location.belowbar, style=shape.circle, color=exitUpSignalColor,   size=size.tiny)
plotshape(showExitSignals  and exitBuySignal  and signalSize == "small",  title='Exit Up Small',  location=location.belowbar, style=shape.circle, color=exitUpSignalColor,   size=size.small)
plotshape(showExitSignals  and exitBuySignal  and signalSize == "normal", title='Exit Up Normal', location=location.belowbar, style=shape.circle, color=exitUpSignalColor,   size=size.normal)

plotshape(showExitSignals  and exitSellSignal and signalSize == "tiny",   title='Exit Down Tiny',   location=location.abovebar, style=shape.circle, color=exitDownSignalColor, size=size.tiny)
plotshape(showExitSignals  and exitSellSignal and signalSize == "small",  title='Exit Down Small',  location=location.abovebar, style=shape.circle, color=exitDownSignalColor, size=size.small)
plotshape(showExitSignals  and exitSellSignal and signalSize == "normal", title='Exit Down Normal', location=location.abovebar, style=shape.circle, color=exitDownSignalColor, size=size.normal)

// Alerts
alertcondition(showBreakSignals and buySignal,     title='VCZ Break Up',    message='Volume Cluster Zones - Break Up')
alertcondition(showBreakSignals and sellSignal,    title='VCZ Break Down',  message='Volume Cluster Zones - Break Down')

alertcondition(showExitSignals and exitBuySignal,  title='VCZ Exit Up',     message='Volume Cluster Zones - Exit Up')
alertcondition(showExitSignals and exitSellSignal, title='VCZ Exit Down',   message='Volume Cluster Zones - Exit Down')