// Regression metrics 
get_historical_slope(float src, int start_index, int window_len) =>
    float sumX  = 0.0
    float sumY  = 0.0
    float sumXY = 0.0
    float sumX2 = 0.0

    for i = start_index to (start_index + window_len - 1)
        float x = i // Bar index or relative index
        float y = src[i]
        sumX  += x
        sumY  += y
        sumXY += x * y
        sumX2 += x * x
        
    float slope = (window_len * sumXY - sumX * sumY) / (window_len * sumX2 - math.pow(sumX, 2))
    slope

// Defining pivots 
piv_hi = ta.pivothigh(high, 10, 10)
piv_lo = ta.pivotlow(low, 10, 10)

// Array for regressions 
var piv_hi_slopes = array.new_float()
var piv_lo_slopes = array.new_float()


if not na(piv_hi)
    float slope_sig = get_historical_slope(high, 10, len)
    array.push(piv_hi_slopes, slope_sig)


if not na(piv_lo)
