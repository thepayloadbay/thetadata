    array.push(piv_lo_slopes, slope_sig)
    

// Calculating the current slope of the pa # helper function 
f_rolling_slope(float src, int len) =>
    y_hat_0 = ta.linreg(src, len, 0)
    y_hat_1 = ta.linreg(src, len, 1)
    float slope = y_hat_0 - y_hat_1
    slope

