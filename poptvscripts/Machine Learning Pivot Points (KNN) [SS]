// KNN ML 
f_knn_k4_dist(float current_val, float[] history_array) =>
    float avg_dist = 1000000.0
    int k = knn_clusters
    if array.size(history_array) >= k
        float[] distances = array.new_float(0)
        for i = 0 to array.size(history_array) - 1
            array.push(distances, math.abs(current_val - array.get(history_array, i)))
        array.sort(distances, order.ascending)
        

        float sum = 0.0
        for i = 0 to k - 1
            sum += array.get(distances, i)
        avg_dist := sum / k
    else if array.size(history_array) > 0
        avg_dist := math.abs(current_val - array.get(history_array, 0))
    
    avg_dist

