indicator('VIX Reversal Scalper by Trend Friend - Stocks Only', shorttitle="VIX Reversal Scalper - Stocks Only", overlay=true)

//Moving Average Type Input
ema = "EMA"
sma = "SMA"
hma = "HMA"
vwma = "VWMA"
wma = "WMA"
rma = "RMA"
symbol = input.symbol("VIX", title="Choose Symbol")
maChoice = input.string("EMA", title="Type of MA To Use", options=[ema, sma, hma, vwma, wma, rma])

//Moving Average Input
vixMaLength = input.int(defval=10, title="Moving Average Length", tooltip="For more signals with earlier entries use lower values. For later signals with less entries use higher values. For scalping use a number of 75 or lower. For swing trades use a number of 100 or higher. Use 1000-3000 for long swings.")

//Turn Signals On/Off
bullOn = input.bool(true, title="Turn Bull Labels On/Off")
bearOn = input.bool(true, title="Turn Bear Labels On/Off")

//Momentum
mom = ta.mom(close, 4)

//VIX Data
vixData = request.security(symbol, "", close)

//VIX Moving Average
vixMa = ta.rma(vixData, vixMaLength)

if maChoice == ema
    vixMa := ta.ema(vixData, vixMaLength)
    
if maChoice == sma
    vixMa := ta.sma(vixData, vixMaLength)
    
if maChoice == hma
    vixMa := ta.hma(vixData, vixMaLength)
    
if maChoice == wma
    vixMa := ta.wma(vixData, vixMaLength)
    
if maChoice == vwma
    vixMa := ta.vwma(vixData, vixMaLength)
    
if maChoice == rma
    vixMa := ta.rma(vixData, vixMaLength)


//Signal Conditions
bool vixBullish = bullOn and ta.crossunder(vixData, vixMa) and mom > mom[1] or bullOn and ta.crossunder(vixData, vixMa) and mom > mom[2] or bullOn and ta.crossunder(vixData, vixMa) and mom[1] > mom[2]
bool vixBearish = bearOn and ta.crossover(vixData, vixMa) and mom < mom[1] or bearOn and ta.crossover(vixData, vixMa) and mom < mom[2] or bearOn and ta.crossover(vixData, vixMa) and mom[1] < mom[2]

