    vixBullish := bearOn and ta.crossover(vixData, vixMa) and mom < mom[1] or bearOn and ta.crossover(vixData, vixMa) and mom < mom[2] or bearOn and ta.crossover(vixData, vixMa) and mom[1] < mom[2]
    
