        pointVol.push(chart.point.from_time(time, norm))
        pointVol.push(chart.point.from_time(time("", -1), norm))
        pointVol.push(chart.point.from_time(time("", -1), 0))

        activePoly.delete()

        pointVol.push(chart.point.from_time(time, 0))
        pointVol.push(chart.point.from_time(pointVol.first().time, 0))

