method pushShift(array<float> id, float value) => 

    id.push(value)

    if id.size() > 100
        id.shift()

    id.percentrank(id.size() - 1)

strongMove() =>

    log   = math.log(close / close[3])
    mean  = ta.sma  (log, 20) 
    stdev = ta.stdev(log, 20, true)
    
    (log - mean) / stdev 


var volRankArr = array.new<float>(), var spreadRankArr = array.new<float>()

barRange     = high - low

volRank      = volRankArr   .pushShift(volume) 
spreadRank   = spreadRankArr.pushShift(barRange)

R            = nz(((close - low) - (high - close)) / barRange, 0)
barDirection = math.sign(close - close[1])
upBar        = barDirection > 0
downBar      = barDirection < 0

[volClass, effort] = switch

    volRank >= ultraHighVolMin => ["Ultra High", "High Effort"]
    volRank >= highVolMin      => ["High", "High Effort"]
    volRank >= lowVolMax       => ["Normal", "Normal"]
    volRank >= ultraLowVolMax  => ["Low", "Low Effort"]
    =>                            ["Ultra Low", "Low Effort"]

spreadClass = switch
    spreadRank >= spreadUltraWideMin   => "Ultra Wide"
    spreadRank >= spreadWideMin        => "Wide"
    spreadRank >= spreadNormalMin      => "Normal"
    spreadRank >= spreadUltraNarrowMax => "Narrow"
    =>                                    "Ultra Narrow"

closePos = switch
    R >=  closeThresh => "High"
    R <= -closeThresh => "Low"
    =>                  "Middle"

body           = math.abs(close - open)
upperWick      = high - math.max(open, close)
lowerWick      = math.min(open, close) - low

bodyRatio      = nz(body / barRange), upperWickRatio = nz(upperWick / barRange), lowerWickRatio = nz(lowerWick / barRange)

smallBody      = bodyRatio <= smallBodyThresh
upRej          = upperWickRatio >= rejWickThresh and upperWickRatio > lowerWickRatio and bodyRatio <= rejBodyMax
lowRej         = lowerWickRatio >= rejWickThresh and lowerWickRatio > upperWickRatio and bodyRatio <= rejBodyMax
wideB          = bodyRatio >= 0.60

shape = switch

    upRej     => "Upper Rejection"
    lowRej    => "Lower Rejection"
    smallBody => "Small-Body"
    wideB     => "Wide-Body"
    =>           "Balanced"

result = switch

    upBar and closePos == "High" and (spreadClass == "Ultra Wide" or spreadClass == "Wide") =>
        "Strong Upward"

    upBar and closePos == "High" and spreadClass == "Normal" =>
        "Moderate Upward"

    upBar and closePos == "Middle" and (spreadClass == "Ultra Wide" or spreadClass == "Wide") =>
        "Questionable Upward"

    upBar and (closePos == "Middle" or closePos == "High") and (spreadClass == "Narrow" or spreadClass == "Ultra Narrow") =>
        "Weak Upward"

    upBar and closePos == "Low" =>
        "Poor Upward"

    downBar and closePos == "Low" and (spreadClass == "Ultra Wide" or spreadClass == "Wide") =>
        "Strong Downward"

    downBar and closePos == "Low" and spreadClass == "Normal" =>
        "Moderate Downward"

    downBar and closePos == "Middle" and (spreadClass == "Ultra Wide" or spreadClass == "Wide") =>
        "Questionable Downward"

    downBar and (closePos == "Middle" or closePos == "Low") and (spreadClass == "Narrow" or spreadClass == "Ultra Narrow") =>
        "Weak Downward"

    downBar and closePos == "High" =>
        "Poor Downward"

    barDirection == 0 and closePos == "High" and (spreadClass == "Ultra Wide" or spreadClass == "Wide") =>
        "Upward Bias"

    barDirection == 0 and closePos == "Low" and (spreadClass == "Ultra Wide" or spreadClass == "Wide") =>
        "Downward Bias"

    barDirection == 0 and closePos == "Middle" and (spreadClass == "Ultra Wide" or spreadClass == "Wide") =>
        "Neutral Wide"

    =>
        "Neutral"

upResult =

     result == "Strong Upward"
  or result == "Moderate Upward"
  or result == "Questionable Upward"
  or result == "Weak Upward"
  or result == "Poor Upward"
  or result == "Upward Bias"

downResult =
     result == "Strong Downward"
  or result == "Moderate Downward"
  or result == "Questionable Downward"
  or result == "Weak Downward"
  or result == "Poor Downward"
  or result == "Downward Bias"

effortVsResult = switch

    effort == "High Effort" and result == "Strong Upward" =>
        "Bullish Efficiency"

    effort == "High Effort" and result == "Strong Downward" =>
        "Bearish Efficiency"

    effort == "High Effort" and upResult and result != "Strong Upward" =>
        "Possible Hidden Weakness"

    effort == "High Effort" and downResult and result != "Strong Downward" =>
        "Possible Hidden Strength"

    effort == "High Effort" and (result == "Neutral" or result == "Neutral Wide") =>
        "Compression / Absorption"

    effort == "Low Effort" and result == "Strong Upward" =>
        "Easy Upward Movement"

    effort == "Low Effort" and result == "Strong Downward" =>
        "Easy Downward Movement"

    effort == "Low Effort" =>
        "Low-Effort / Low-Result"

    effort == "Normal" and (result == "Strong Upward" or result == "Moderate Upward") =>
        "Constructive Upward"

    effort == "Normal" and (result == "Strong Downward" or result == "Moderate Downward") =>
        "Constructive Downward"

    effort == "Normal" =>
        "Neutral / Mixed"

    =>
        "Unclassified"

bullScore = switch

    effortVsResult == "Bullish Efficiency"   => 3
    effortVsResult == "Easy Upward Movement" => 1
    effortVsResult == "Constructive Upward"  => 2

    => 0.0

bearScore = switch

    effortVsResult == "Bearish Efficiency"     => 3
    effortVsResult == "Easy Downward Movement" => 1
    effortVsResult == "Constructive Downward"  => 2

    => 0.0

strengthScore = math.sum(bullScore, bgLookback)
weaknessScore = math.sum(bearScore, bgLookback)

if trendRule

    switch direction == 1 

        true => strengthScore += 5 
        =>      weaknessScore += 5

netScore = strengthScore - weaknessScore

background = switch

    netScore > bgThresh  => "Strong"
    netScore < -bgThresh => "Weak"

    => "Neutral"

strongBg = background == "Strong"
weakBg   = background == "Weak"

bgConditionCol = color.from_gradient(netScore, -10, 10, color.rgb(255, 116, 116), #55ffda)

volLessP2         = volume < volume[1] and volume < volume[2]
lowVolVsa         = effort == "Low Effort" or volLessP2

narrowSpread = spreadClass == "Narrow" or spreadClass == "Ultra Narrow" 

noDemand = switch noDemandTrad
    
    false => upBar
             and (lowVolVsa or (volLessP2))
             and narrowSpread
             and closePos == "Middle"

    => upBar and volLessP2 and narrowSpread

noSupply = switch noSupplyTrad

    false => downBar
             and (lowVolVsa or (volLessP2))
             and narrowSpread
             and closePos == "Middle"

    => downBar and volLessP2 and narrowSpread

noDemandConfirmed = noDemand[1] and close < close[1]
noSupplyConfirmed = noSupply[1] and close > close[1]

upthrust =
     shape        == "Upper Rejection"
 and closePos     == "Middle"
 and (spreadClass == "Normal" or spreadClass == "Wide" or spreadClass == "Ultra Wide")
 and weakBg
 and (upThrustTrad ? direction == -1 : true)

shakeout =
     shape        == "Lower Rejection"
 and (closePos    == "Middle" or closePos    == "High")
 and (spreadClass == "Normal" or spreadClass == "Wide" or spreadClass == "Ultra Wide")
 and strongBg
 and (shakeOutTrad ? direction == 1 : true)


