        var polylinesOIdn = array.new<polyline>()

        oiMin = oiArr.min()
        oiRange = oiArr.range()


        pointsSizeUp = pointOIup.size()
        pointsSizeDn = pointOIdn.size()

        if pointOIup.size() > 0 and pointOIdn.size() > 0

            idx = 0

            for i = 0 to pointOIup.size() - 1 by 4

