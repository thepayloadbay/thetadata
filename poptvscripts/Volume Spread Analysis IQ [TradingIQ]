if showVol
        
    var volArr = array.new<float>()
    var pointVol = array.new<chart.point>()
    var polylines = array.new<polyline>()
    var polyline activePoly = na

    volArr.push(volume)

    if not barstate.islast 

        pointVol.push(chart.point.from_time(time, 0))
        pointVol.push(chart.point.from_time(time, float(na)))
        pointVol.push(chart.point.from_time(time("", -1), float(na)))
        pointVol.push(chart.point.from_time(time("", -1), 0))

    else 

