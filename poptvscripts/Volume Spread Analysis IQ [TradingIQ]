                sliceDn.push(chart.point.from_time(sliceDn.first().time, 0))

                polylinesOIdn.push(polyline.new(sliceDn, line_color = color.new(oiDnCol, oiLineTransp), fill_color = color.new(oiDnCol, oiFillTransp), xloc = xloc.bar_time))

